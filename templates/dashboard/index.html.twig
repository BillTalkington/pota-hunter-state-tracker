{% extends 'base.html.twig' %}

{% block title %}Hello POTA Hunter!{% endblock %}

{% block body %}
<style>
    .wrapper { margin: 1em auto; max-width: 800px; width: 95%; font: 18px/1.5 sans-serif; }
    .wrapper code { background: #F5F5F5; padding: 2px 6px; }
</style>

<div class="wrapper">
    <h1>Hello POTA Hunter! &#128526;</h1>

    Below you will find:
    <ul>
        <li><code>Worked</code> states with successful QSO counts</li>
        <li><code>Needed</code> states towards your 'Hunted All States' award</li>
    </ul>

    <div class="row">
        <div class="col">
            <h2>Worked States</h2>

            <ul>
                {% for item in workedStates %}
                    <li>
                        {{ item.state.label }}
                        ({{ item.count }})
                    </li>
                {% endfor %}
            </ul>
        </div>

        <div class="col">
            <h2>Needed States</h2>

            <ul>
                {% for item in neededStates %}
                    <li>
                        {{ item.state.label }}
                    </li>
                {% endfor %}
            </ul>
        </div>
    </div>
</div>
{% endblock %}
