{% extends 'base.html.twig' %}

{% block title %}Hello POTA Hunter!{% endblock %}

{% block body %}
<style>
    .example-wrapper { margin: 1em auto; max-width: 800px; width: 95%; font: 18px/1.5 sans-serif; }
    .example-wrapper code { background: #F5F5F5; padding: 2px 6px; }
</style>

<div class="example-wrapper">
    <h1>Hello POTA Hunter! &#128526;</h1>

    Below you will find:
    <ul>
        <li><code>Worked</code> states with successful QSO counts</li>
        <li><code>Needed</code> states towards your 'Hunted All States' award</li>
    </ul>

    {% for item in states %}
        <div>
            {{ item.state.label }}
            {{ item.count }}

            {% if item.worked %}
                Worked
            {% else %}
                Needed
            {% endif %}
        </div>
    {% endfor %}
</div>
{% endblock %}
